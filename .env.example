# PostgreSQL is required for real backend storage.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trendbrain_core?schema=public"

# Server
PORT=3000
DISABLE_CRON=false
PRISMA_LOG=false
ALLOWED_ORIGIN=""
ADMIN_API_TOKEN="change-me-before-hosting"

# Optional AI providers. Configure one for AI-generated summaries and recommendations.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# Ollama-compatible fallback. Example: http://localhost:11434
OLLAMA_BASE_URL=""
OLLAMA_MODEL="llama3.1"

# Python Google Trends collector.
PYTHON_BIN="python"

# Legacy Gemini keys are not used by the real backend pipeline.
GEMINI_API_KEY=""
