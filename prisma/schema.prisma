generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Signal {
  id          String   @id @default(cuid())
  source      String
  sourceUrl   String?
  keyword     String
  title       String?
  content     String?
  category    String?
  region      String   @default("Nepal")
  metricsJson Json?
  collectedAt DateTime @default(now())

  @@index([source, collectedAt])
  @@index([keyword, collectedAt])
}

model ProductSignal {
  id                String   @id @default(cuid())
  platform          String
  productName       String
  category          String?
  price             Float?
  rating            Float?
  reviewCount       Int?
  reviewText        String?
  complaintKeywords Json?
  sourceUrl         String?
  collectedAt       DateTime @default(now())

  @@index([platform, collectedAt])
  @@index([category, collectedAt])
}

model RetailerSignal {
  id           String   @id @default(cuid())
  retailerName String
  location     String
  signalType   String
  productName  String
  category     String?
  note         String
  urgency      Int
  createdAt    DateTime @default(now())

  @@index([location, createdAt])
  @@index([productName, createdAt])
}

model Trend {
  id                               String   @id @default(cuid())
  name                             String
  category                         String?
  region                           String   @default("Nepal")
  demandScore                      Float
  velocityScore                    Float
  competitionScore                 Float
  marginScore                      Float
  retailerPullScore                Float
  viralityScore                    Float
  manufacturingEaseScore           Float
  distributionFeasibilityScore     Float
  riskScore                        Float
  finalScore                       Float
  lifecycleStage                   String
  summary                          String?
  recommendation                   String?
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt

  @@unique([name, region])
  @@index([finalScore])
  @@index([updatedAt])
}

model AIReport {
  id                  String   @id @default(cuid())
  title               String
  region              String   @default("Nepal")
  summary             String
  opportunitiesJson   Json
  risksJson           Json
  recommendationsJson Json
  createdAt           DateTime @default(now())

  @@index([createdAt])
}

model CollectorRun {
  id           String   @id @default(cuid())
  collector    String
  status       String
  message      String?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  itemsCreated Int      @default(0)

  @@index([collector, startedAt])
}
